---
profile: moderate
offline: true

exclude_paths:
  - .git/
  - .cache/
  - collections/

# Collections are fetched on the control node (galaxy egress via NAT); in
# CI/dev without them, mock the external modules so rules can still run.
mock_modules:
  - azure.azcollection.azure_keyvault_secret
  - microsoft.ad.domain
  - microsoft.ad.domain_controller
  - microsoft.ad.membership
  - ansible.windows.win_feature
  - ansible.windows.win_service
  - ansible.windows.win_share
  - ansible.windows.win_powershell
  - ansible.windows.win_package
  - ansible.windows.win_updates
  - ansible.windows.win_reboot
  - ansible.windows.win_file
  - chocolatey.chocolatey.win_chocolatey
  - ansible.mariadb.mariadb_user
  - ansible.mariadb.mariadb_db
  - community.windows.win_timezone
  - ansible.windows.win_timezone
  - community.general.timezone
  - ansible.posix.firewalld
  - ansible.windows.win_dns_client

warn_list:
  - experimental
  - command-instead-of-module
