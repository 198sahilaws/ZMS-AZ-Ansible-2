# /etc/ansible/estate.env
# Terraform cloud-init writes this on the real control node. This example is
# for local/manual runs. NAMES ONLY - never put secret material here; the
# node reads secrets from Key Vault via its Managed Identity.
AZURE_KEYVAULT_URL=https://<vault-name>.vault.azure.net/
ANSIBLE_SECRET_NAME=<consolidated-secret-name>
AZURE_SUBSCRIPTION_ID=<subscription-id>
AZURE_RESOURCE_GROUP=<resource-group>
ANSIBLE_AZURE_VM_RESOURCE_GROUPS=<resource-group>
AZURE_CLIENT_ID=<control-identity-client-id>
ANSIBLE_AZURE_AUTH_SOURCE=msi
CONTROL_REPO_DIR=/opt/control-repo
RECONVERGE_MINUTES=60

# Optional failure alerting (leave unset to disable):
# ALERT_EVENTGRID_TOPIC_URL=https://<topic>.<region>-1.eventgrid.azure.net/api/events
# ALERT_EVENTGRID_KEY=<sas-key>
